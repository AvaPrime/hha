## 2. Add: Health Adapter CMOs (NEW TABLES)

### 🔍 `health_diagnoses`

```sql
CREATE TABLE health_diagnoses (
  diagnosis_id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  trace_id               TEXT NOT NULL,

  primary_diagnosis      TEXT NOT NULL,
  secondary_diagnoses    TEXT[] DEFAULT '{}',

  symptom                TEXT NOT NULL,
  immediate_cause        TEXT,
  root_cause             TEXT,
  contributing_factors   JSONB DEFAULT '[]',

  impact_scope           TEXT,
  severity               severity NOT NULL,

  confidence_score       NUMERIC(4,3) NOT NULL CHECK (confidence_score BETWEEN 0 AND 1),

  related_anomaly_ids    UUID[] DEFAULT '{}',
  evidence_observation_ids UUID[] DEFAULT '{}',

  status                 TEXT DEFAULT 'active',

  created_at             TIMESTAMPTZ DEFAULT now(),

  ledger_sequence        BIGSERIAL,
  subsystem              TEXT DEFAULT 'hha'
);
```

---

### 🛠️ `health_remediation_plans`

```sql
CREATE TABLE health_remediation_plans (
  plan_id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  trace_id               TEXT NOT NULL,

  diagnosis_id           UUID REFERENCES health_diagnoses(diagnosis_id),

  plan_steps             JSONB NOT NULL,
  policy_mode            TEXT NOT NULL,
  requires_approval      BOOLEAN DEFAULT TRUE,

  estimated_risk         TEXT,
  estimated_recovery_probability NUMERIC(4,3),

  confidence_score       NUMERIC(4,3),

  created_at             TIMESTAMPTZ DEFAULT now(),

  ledger_sequence        BIGSERIAL,
  subsystem              TEXT DEFAULT 'hha'
);
```

---

### ⚙️ `health_action_events`

```sql
CREATE TABLE health_action_events (
  action_event_id        UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  trace_id               TEXT NOT NULL,

  plan_id                UUID REFERENCES health_remediation_plans(plan_id),

  action_type            TEXT NOT NULL,
  target                 TEXT,

  started_at             TIMESTAMPTZ,
  ended_at               TIMESTAMPTZ,

  result_status          TEXT,
  exit_code              INTEGER,

  stdout_ref             JSONB,
  stderr_ref             JSONB,

  artifact_refs          JSONB DEFAULT '[]',

  created_at             TIMESTAMPTZ DEFAULT now(),

  ledger_sequence        BIGSERIAL,
  subsystem              TEXT DEFAULT 'hha'
);
```

---

### ✅ `health_verification_results`

```sql
CREATE TABLE health_verification_results (
